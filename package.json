{
  "name": "freeresource",
  "private": false,
  "description": "A local-first, AI-powered personal tool and asset manager built with an infinite canvas workflow.",
  "repository": "Lam10086/ToolVault",
  "version": "1.0.0",
  "author": "TiAmoLam <tiamolam@freeresource.com>",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "dev:electron": "concurrently \"vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "build:electron": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.freeresource.app",
    "productName": "FreeResource",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "identity": null
    },
    "win": {
      "target": ["nsis"]
    },
    "linux": {
      "target": ["AppImage"]
    }
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@xyflow/react": "^12.10.2",
    "clsx": "^2.1.1",
    "fuse.js": "^7.3.0",
    "html-to-image": "^1.11.13",
    "idb-keyval": "^6.2.4",
    "lucide-react": "^1.16.0",
    "nvm": "^0.0.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-zoom-pan-pinch": "^4.0.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
